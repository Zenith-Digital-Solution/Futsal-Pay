PYTHONPATH=.
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app
ACCESS_TOKEN_EXPIRE_MINUTES=11520
SECRET_KEY=test_secret_key
DATABASE_URI=sqlite+aiosqlite:///./db.sqlite3
DEBUG=True

# Redis settings (only used in production when DEBUG=False)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password  # Uncomment if Redis requires authentication
REDIS_MAX_CONNECTIONS=10

# Email settings
EMAIL_ENABLED=False
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=user@example.com
EMAIL_HOST_PASSWORD=password
EMAIL_FROM_ADDRESS=noreply@example.com
# =============================================================================
# PAYOUT CONFIGURATION
# =============================================================================
#
# PAYOUT_MODE controls where booking payments first land:
#
#   PLATFORM  (recommended — platform collects, then pushes to owners at midnight)
#     All player payments → platform merchant account (PLATFORM_* creds below).
#     Midnight Celery job transfers net to each owner's configured gateway.
#     Superuser can inspect, hold, or release funds from the dashboard.
#
#   DIRECT  (owner-as-merchant — money bypasses platform entirely)
#     Player pays → owner's own Khalti/eSewa account directly.
#     Midnight job just marks ledger settled (no transfer needed).
#     Owner must configure and verify their gateway in the owner dashboard.
#
# Switch by changing this one line. No code changes needed.
# =============================================================================
PAYOUT_MODE=PLATFORM

# Platform fee % kept by the superuser (applied in both modes for accounting).
PLATFORM_FEE_PCT=5.0

# ── Platform (Superuser) Khalti — PLATFORM mode ───────────────────────────────
# Merchant account where all booking payments land first.
PLATFORM_KHALTI_SECRET_KEY=your-platform-khalti-secret-key
PLATFORM_KHALTI_MOBILE=98XXXXXXXX

# ── Platform (Superuser) eSewa — PLATFORM mode ────────────────────────────────
PLATFORM_ESEWA_MERCHANT_CODE=YOUR_MERCHANT_CODE
PLATFORM_ESEWA_SECRET_KEY=your-esewa-secret-key

# ── Platform Bank Account — PLATFORM mode (for bank-transfer payouts to owners)
PLATFORM_BANK_NAME=Nepal Investment Mega Bank
PLATFORM_BANK_ACCOUNT_NUMBER=0000000000000
PLATFORM_BANK_ACCOUNT_NAME=FutsalApp Pvt Ltd
PLATFORM_BANK_SWIFT_CODE=NIBLNPKT

# ── PostHog Analytics (server-side) ──────────────────────────────────────────
# Get your key at https://app.posthog.com → Project Settings → Project API key
POSTHOG_ENABLED=false
POSTHOG_API_KEY=phc_xxxx
POSTHOG_HOST=https://us.i.posthog.com
